# ── Money Leak Detector — environment variables ─────────────────────
# Copy this file to .env.local and fill in your own values.
# Every variable here is safe to expose to the browser (NEXT_PUBLIC_*);
# no server-side secrets are required to run the app.

# Your Supabase project URL and anon (public) key.
# Find both in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-SUPABASE-ANON-KEY

# The canonical URL of your deployment (no trailing slash).
# Used for auth redirects and metadata. For local dev:
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Set to "1" to show the "Continue with Google" button.
# Requires the Google provider to be enabled in Supabase
# (Authentication → Sign In / Providers → Google).
NEXT_PUBLIC_GOOGLE_AUTH=0
