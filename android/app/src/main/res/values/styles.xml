<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <!-- noir window background: on Android 15+ edge-to-edge, the
             status/gesture bar areas show the window background, so it
             must match the app theme -->
        <item name="android:windowBackground">@color/colorPrimary</item>
        <!-- noir status/navigation bars matching the app theme -->
        <item name="android:statusBarColor">#0A0C10</item>
        <item name="android:navigationBarColor">#0A0C10</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>


    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <!-- Android 12+ system splash: noir field behind the app icon
             (the full-artwork splash is shown right after by the
             Capacitor SplashScreen plugin) -->
        <item name="windowSplashScreenBackground">#0A0C10</item>
        <item name="android:background">@drawable/splash</item>
    </style>
</resources>